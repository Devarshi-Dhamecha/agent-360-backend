# Django Settings
DEBUG=True

# Database Configuration
DB_ENGINE=django.db.backends.postgresql
DB_NAME=agent360_db
DB_USER=postgres
DB_PASSWORD=your-password-here
DB_HOST=localhost
DB_PORT=5432

# Allowed Hosts
ALLOWED_HOSTS=127.0.0.1,localhost,.ngrok-free.app,.ngrok.io,.ngrok.app
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://red-coyote-805490.hostingersite.com

# ALB Authentication Configuration
# Set to 'true' to enable ALB OIDC authentication (production)
# Set to 'false' for local development without ALB
ALB_AUTH_ENABLED=false

# AWS Region for ALB public key fetching
AWS_REGION=us-east-1

# ALB Key Cache Settings (optional)
ALB_KEY_CACHE_TTL=3600
ALB_KEY_CACHE_MAX_SIZE=100
